<script>
document.addEventListener("DOMContentLoaded", function () {

    const allCheckboxes = document.querySelectorAll(".row-check");
    const checkAll = document.getElementById("checkAll");
    const btnApprove = document.getElementById("btnApprove");
    const btnCancel = document.getElementById("btnCancel");
    const form = document.getElementById("mainForm");

    let activeFlag = null;
    let isSubmitting = false;

    // ===============================
    // ตรวจสอบว่ามีสถานะเดียวทั้งหมดไหม
    // ===============================
    function detectSingleStatus() {
        const flags = Array.from(allCheckboxes).map(cb => cb.dataset.flag);
        const uniqueFlags = [...new Set(flags)];

        if (uniqueFlags.length === 1) {
            activeFlag = uniqueFlags[0];
        }
    }

    // ===============================
    // Reset UI
    // ===============================
    function resetUI() {
        activeFlag = null;
        allCheckboxes.forEach(cb => cb.disabled = false);
        btnApprove.disabled = true;
        btnCancel.disabled = true;
        checkAll.checked = false;
    }

    // ===============================
    // Update UI
    // ===============================
    function updateUI() {

        const checked = document.querySelectorAll(".row-check:checked");

        if (checked.length === 0) {
            resetUI();
            return;
        }

        activeFlag = checked[0].dataset.flag;

        allCheckboxes.forEach(cb => {
            if (cb.dataset.flag !== activeFlag && !cb.checked) {
                cb.disabled = true;
            }
        });

        btnApprove.disabled = activeFlag !== "false";
        btnCancel.disabled = activeFlag !== "true";

        const sameStatus = Array.from(allCheckboxes)
            .filter(cb => cb.dataset.flag === activeFlag);

        const sameChecked = sameStatus.filter(cb => cb.checked);

        checkAll.checked = sameStatus.length === sameChecked.length;
    }

    // ===============================
    // Event เลือกทีละรายการ
    // ===============================
    allCheckboxes.forEach(cb => {
        cb.addEventListener("change", updateUI);
    });

    // ===============================
    // Select All
    // ===============================
    checkAll.addEventListener("change", function () {

        if (!activeFlag) {
            const flags = Array.from(allCheckboxes).map(cb => cb.dataset.flag);
            const uniqueFlags = [...new Set(flags)];

            if (uniqueFlags.length > 1) {
                Swal.fire({
                    icon: 'warning',
                    title: 'ไม่สามารถเลือกทั้งหมดได้',
                    text: 'กรุณาเลือกอย่างน้อย 1 รายการเพื่อกำหนดสถานะก่อน',
                    confirmButtonText: 'ตกลง',
                    confirmButtonColor: '#d33'
                });

                this.checked = false;
                return;
            }

            activeFlag = uniqueFlags[0];
        }

        allCheckboxes.forEach(cb => {
            if (cb.dataset.flag === activeFlag) {
                cb.checked = this.checked;
            }
        });

        updateUI();
    });

    // ===============================
    // เตรียม Submit
    // ===============================
    function prepareSubmit(actionUrl, actionText, successText) {

        if (isSubmitting) return;

        const selected = document.querySelectorAll(".row-check:checked");

        if (selected.length === 0) {
            Swal.fire({
                icon: 'error',
                title: 'กรุณาเลือกรายการ',
                text: 'คุณยังไม่ได้เลือกรายการที่ต้องการดำเนินการ',
                confirmButtonText: 'ตกลง'
            });
            return;
        }

        Swal.fire({
            title: `ยืนยัน${actionText}?`,
            html: `
                <b>จำนวนรายการ:</b> ${selected.length} รายการ<br>
            `,
            icon: 'question',
            showCancelButton: true,
            cancelButtonText: 'ยกเลิก',
            confirmButtonText: 'ยืนยัน',
            confirmButtonColor: '#198754',
            cancelButtonColor: '#DC3545',
            reverseButtons: true
        }).then((result) => {

            if (result.isConfirmed) {

                isSubmitting = true;

                Swal.fire({
                    title: 'กำลังดำเนินการ...',
                    html: 'กรุณารอสักครู่',
                    allowOutsideClick: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });

                // เปิด checkbox ทั้งหมดก่อน submit
                allCheckboxes.forEach(cb => cb.disabled = false);

                form.action = actionUrl;
                form.submit();
            }
        });
    }

    // ===============================
    // Approve
    // ===============================
    btnApprove.addEventListener("click", function () {
        prepareSubmit(
            '@Url.Action("ApproveSelectedOut", "Vw_Approve")',
            'การอนุมัติ',
            'อนุมัติสำเร็จ'
        );
    });

    // ===============================
    // Cancel
    // ===============================
    btnCancel.addEventListener("click", function () {
        prepareSubmit(
            '@Url.Action("CancelSelectedOut", "Vw_Approve")',
            'การยกเลิกอนุมัติ',
            'ยกเลิกสำเร็จ'
        );
    });

    // เริ่มต้น
    btnApprove.disabled = true;
    btnCancel.disabled = true;

    detectSingleStatus();
});
</script>
